# Copy to pet-sitting/scripts/.env and fill in (never commit .env)

# Your own domain — share https://YOUR_DOMAIN/book/ (no GitHub username in the link)
# Run: bash scripts/setup-custom-domain.sh www.petsittersclub.co.uk
# CUSTOM_DOMAIN=www.petsittersclub.co.uk

# Optional — agent deploys code for you (owner never uses Netlify)
# NETLIFY_AUTH_TOKEN=nfp_...
# NETLIFY_SITE_ID=optional-if-site-name-is-petsittersclublondon

# Optional — agent updates calendar from scripts (owner normally uses the website)
LIVE_STORE_URL=https://petsittersclublondon.netlify.app/.netlify/functions/store

# Gmail inbox that receives pet sitting enquiries
GMAIL_IMAP_USER=your.name@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Only process emails sent to this address (matches config.js bookingEmail)
BOOKING_EMAIL=petsittersclublondon@gmail.com

# --- Owner notifications (pick one channel) ---
# telegram | email | mac
NOTIFY_CHANNEL=telegram

# Telegram (recommended — free, works on your phone)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your new bot (tap Start)
# 3. Run: python3 scripts/telegram-chat-id.py  (prints your chat id)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your_chat_id

# Email fallback (also used to send client quotes)
NOTIFY_EMAIL=your.name@gmail.com
